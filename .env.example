# Copy to .env / .env.local and fill in values. Never commit real secrets.

# OpenRouter — required for: npx tsx scripts/generate-llm-descriptions.ts and news rewriting
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic — direct Claude API for news rewrites (Terry voice)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Unsplash — image search for /news section
# Create a key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Publer — social media auto-posting (Facebook + X) on news approval
# Get key: app.publer.com → Settings → Access & Login → API Keys
PUBLER_API_KEY=
